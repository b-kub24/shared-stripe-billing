    "stripe": "^14.0.0 || ^15.0.0 || ^16.0.0"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.0",
    "next": "^14.2.0",
    "react": "^18.3.0",
    "stripe": "^16.0.0",
    "typescript": "^5.5.0"
  },
  "keywords": ["stripe","billing","nextjs","supabase","subscriptions","payments","checkout","saas"],
  "author": "b-kub24",
